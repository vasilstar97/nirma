{"external_factors": ["\u0412\u044b\u0441\u043e\u043a\u0438\u0439 \u0443\u0440\u043e\u0432\u0435\u043d\u044c \u0435\u0441\u0442\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0433\u043e \u043f\u0440\u0438\u0440\u043e\u0441\u0442\u0430 \u043d\u0430\u0441\u0435\u043b\u0435\u043d\u0438\u044f \u0432 \u041b\u0435\u043d\u0438\u043d\u0433\u0440\u0430\u0434\u0441\u043a\u043e\u0439 \u043e\u0431\u043b\u0430\u0441\u0442\u0438 (0,7% \u0432 2024 \u0433\u043e\u0434\u0443)", "\u041d\u0430\u043b\u0438\u0447\u0438\u0435 \u0444\u0435\u0434\u0435\u0440\u0430\u043b\u044c\u043d\u043e\u0439 \u0442\u0440\u0430\u0441\u0441\u044b \u0410-215 '\u0421\u0430\u043d\u043a\u0442-\u041f\u0435\u0442\u0435\u0440\u0431\u0443\u0440\u0433 - \u0412\u044b\u0442\u0435\u0433\u0440\u0430' \u0447\u0435\u0440\u0435\u0437 \u0442\u0435\u0440\u0440\u0438\u0442\u043e\u0440\u0438\u044e \u0440\u0430\u0439\u043e\u043d\u0430", "\u0420\u0435\u0430\u043b\u0438\u0437\u0430\u0446\u0438\u044f \u0433\u043e\u0441\u0443\u0434\u0430\u0440\u0441\u0442\u0432\u0435\u043d\u043d\u043e\u0439 \u043f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u044b \u0440\u0430\u0441\u0441\u0435\u043b\u0435\u043d\u0438\u044f \u0430\u0432\u0430\u0440\u0438\u0439\u043d\u043e\u0433\u043e \u0436\u0438\u043b\u0438\u0449\u043d\u043e\u0433\u043e \u0444\u043e\u043d\u0434\u0430", "\u041f\u043e\u043b\u0438\u0442\u0438\u043a\u0430 \u0433\u0430\u0437\u0438\u0444\u0438\u043a\u0430\u0446\u0438\u0438 \u043d\u0430\u0441\u0435\u043b\u0435\u043d\u043d\u044b\u0445 \u043f\u0443\u043d\u043a\u0442\u043e\u0432 \u041b\u0435\u043d\u0438\u043d\u0433\u0440\u0430\u0434\u0441\u043a\u043e\u0439 \u043e\u0431\u043b\u0430\u0441\u0442\u0438", "\u0420\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u043b\u0435\u0441\u043e\u043f\u0440\u043e\u043c\u044b\u0448\u043b\u0435\u043d\u043d\u043e\u0433\u043e \u043a\u043e\u043c\u043f\u043b\u0435\u043a\u0441\u0430 \u043a\u0430\u043a \u0441\u0442\u0440\u0430\u0442\u0435\u0433\u0438\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u043d\u0430\u043f\u0440\u0430\u0432\u043b\u0435\u043d\u0438\u044f \u044d\u043a\u043e\u043d\u043e\u043c\u0438\u043a\u0438 \u0440\u0435\u0433\u0438\u043e\u043d\u0430", "\u041d\u0430\u043b\u0438\u0447\u0438\u0435 \u0441\u0438\u0441\u0442\u0435\u043c\u044b \u041e\u041e\u041f\u0422 \u0440\u0435\u0433\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u043e\u0433\u043e \u0437\u043d\u0430\u0447\u0435\u043d\u0438\u044f (\u041f\u0440\u0438\u0440\u043e\u0434\u043d\u044b\u0439 \u043f\u0430\u0440\u043a '\u0412\u0435\u043f\u0441\u0441\u043a\u0438\u0439 \u043b\u0435\u0441')", "\u041d\u0430\u043b\u0438\u0447\u0438\u0435 \u041e\u043d\u0435\u0436\u0441\u043a\u043e\u0433\u043e \u043e\u0437\u0435\u0440\u0430 (\u0441\u0430\u043c\u043e\u0435 \u0447\u0438\u0441\u0442\u043e\u0435 \u0432 \u0415\u0432\u0440\u043e\u043f\u0435) \u0438 \u0440\u0435\u043a\u0438 \u0421\u0432\u0438\u0440\u044c \u0434\u043b\u044f \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044f \u0442\u0443\u0440\u0438\u0437\u043c\u0430 \u0438 \u043b\u043e\u0433\u0438\u0441\u0442\u0438\u043a\u0438"], "internal_factors": ["\u0412\u044b\u0441\u043e\u043a\u0438\u0439 \u0440\u0435\u0439\u0442\u0438\u043d\u0433 \u044d\u0444\u0444\u0435\u043a\u0442\u0438\u0432\u043d\u043e\u0441\u0442\u0438 \u0434\u0435\u044f\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u0438 \u0430\u0434\u043c\u0438\u043d\u0438\u0441\u0442\u0440\u0430\u0446\u0438\u0438 (1 \u043c\u0435\u0441\u0442\u043e \u0432 \u0440\u0435\u0439\u0442\u0438\u043d\u0433\u0435 '47' \u0432 1 \u043a\u0432\u0430\u0440\u0442\u0430\u043b\u0435 2025 \u0433\u043e\u0434\u0430)", "\u041b\u0438\u0434\u0438\u0440\u0443\u044e\u0449\u0438\u0435 \u043f\u043e\u0437\u0438\u0446\u0438\u0438 \u043f\u043e \u0440\u0435\u0430\u043b\u0438\u0437\u0430\u0446\u0438\u0438 \u043f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u044b \u0440\u0430\u0441\u0441\u0435\u043b\u0435\u043d\u0438\u044f \u0430\u0432\u0430\u0440\u0438\u0439\u043d\u043e\u0433\u043e \u0436\u0438\u043b\u044c\u044f", "\u041d\u0430\u043b\u0438\u0447\u0438\u0435 \u0440\u0430\u0437\u0432\u0438\u0442\u043e\u0439 \u043b\u0435\u0441\u043e\u0437\u0430\u0433\u043e\u0442\u043e\u0432\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0439 \u0438 \u0434\u0435\u0440\u0435\u0432\u043e\u043e\u0431\u0440\u0430\u0431\u0430\u0442\u044b\u0432\u0430\u044e\u0449\u0435\u0439 \u043f\u0440\u043e\u043c\u044b\u0448\u043b\u0435\u043d\u043d\u043e\u0441\u0442\u0438", "\u041a\u0440\u0438\u0442\u0438\u0447\u0435\u0441\u043a\u0438\u0439 \u0438\u0437\u043d\u043e\u0441 \u0441\u0435\u0442\u0435\u0439 \u0432\u043e\u0434\u043e\u0441\u043d\u0430\u0431\u0436\u0435\u043d\u0438\u044f (\u0434\u043e 90%)", "\u041d\u0430\u043b\u0438\u0447\u0438\u0435 \u043f\u0440\u0438\u0440\u043e\u0434\u043d\u043e\u0433\u043e \u043f\u0430\u0440\u043a\u0430 '\u0412\u0435\u043f\u0441\u0441\u043a\u0438\u0439 \u043b\u0435\u0441' \u0438 \u0441\u0438\u0441\u0442\u0435\u043c\u044b \u041e\u041e\u041f\u0422", "\u041f\u0440\u043e\u0442\u044f\u0436\u0435\u043d\u043d\u043e\u0441\u0442\u044c \u0434\u043e\u0440\u043e\u0436\u043d\u043e\u0439 \u0441\u0435\u0442\u0438 775,318 \u043a\u043c \u0441 \u0444\u0435\u0434\u0435\u0440\u0430\u043b\u044c\u043d\u043e\u0439 \u0442\u0440\u0430\u0441\u0441\u043e\u0439", "\u041d\u0430\u043b\u0438\u0447\u0438\u0435 \u0432\u043e\u0434\u043d\u044b\u0445 \u0442\u0440\u0430\u043d\u0441\u043f\u043e\u0440\u0442\u043d\u044b\u0445 \u043f\u0443\u0442\u0435\u0439 \u043f\u043e \u0440\u0435\u043a\u0435 \u0421\u0432\u0438\u0440\u044c \u0438 \u041e\u043d\u0435\u0436\u0441\u043a\u043e\u043c\u0443 \u043e\u0437\u0435\u0440\u0443", "\u041e\u0433\u0440\u0430\u043d\u0438\u0447\u0435\u043d\u043d\u043e\u0435 \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u0433\u043e\u0440\u043e\u0434\u0441\u043a\u043e\u0433\u043e \u043f\u0430\u0441\u0441\u0430\u0436\u0438\u0440\u0441\u043a\u043e\u0433\u043e \u0442\u0440\u0430\u043d\u0441\u043f\u043e\u0440\u0442\u0430", "\u041f\u043e\u0441\u0442\u0435\u043f\u0435\u043d\u043d\u0430\u044f \u0433\u0430\u0437\u0438\u0444\u0438\u043a\u0430\u0446\u0438\u044f \u043d\u0430\u0441\u0435\u043b\u0435\u043d\u043d\u044b\u0445 \u043f\u0443\u043d\u043a\u0442\u043e\u0432 \u0440\u0430\u0439\u043e\u043d\u0430", "\u041d\u0430\u043b\u0438\u0447\u0438\u0435 \u0433\u0440\u0443\u0437\u043e\u0432\u044b\u0445 \u043f\u0440\u0438\u0447\u0430\u043b\u043e\u0432 \u0432 \u043d\u0430\u0441\u0435\u043b\u0435\u043d\u043d\u044b\u0445 \u043f\u0443\u043d\u043a\u0442\u0430\u0445 (\u0412\u0430\u0436\u0438\u043d\u044b, \u0412\u043e\u0437\u043d\u0435\u0441\u0435\u043d\u044c\u0435, \u041f\u043e\u0434\u043f\u043e\u0440\u043e\u0436\u044c\u0435)"], "mission": "\u0424\u043e\u0440\u043c\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435 \u043a\u043e\u043c\u0444\u043e\u0440\u0442\u043d\u043e\u0439, \u044d\u043a\u043e\u043b\u043e\u0433\u0438\u0447\u0435\u0441\u043a\u0438 \u0431\u0435\u0437\u043e\u043f\u0430\u0441\u043d\u043e\u0439 \u0438 \u044d\u043a\u043e\u043d\u043e\u043c\u0438\u0447\u0435\u0441\u043a\u0438 \u0434\u0438\u0432\u0435\u0440\u0441\u0438\u0444\u0438\u0446\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u043e\u0439 \u0442\u0435\u0440\u0440\u0438\u0442\u043e\u0440\u0438\u0438 \u041f\u043e\u0434\u043f\u043e\u0440\u043e\u0436\u0441\u043a\u043e\u0433\u043e \u043c\u0443\u043d\u0438\u0446\u0438\u043f\u0430\u043b\u044c\u043d\u043e\u0433\u043e \u0440\u0430\u0439\u043e\u043d\u0430 \u043d\u0430 \u043e\u0441\u043d\u043e\u0432\u0435 \u044d\u0444\u0444\u0435\u043a\u0442\u0438\u0432\u043d\u043e\u0433\u043e \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0438\u044f \u043f\u0440\u0438\u0440\u043e\u0434\u043d\u043e-\u0440\u0435\u0441\u0443\u0440\u0441\u043d\u043e\u0433\u043e \u043f\u043e\u0442\u0435\u043d\u0446\u0438\u0430\u043b\u0430 (\u043b\u0435\u0441, \u0432\u043e\u0434\u0430, \u041e\u041e\u041f\u0422), \u043c\u043e\u0434\u0435\u0440\u043d\u0438\u0437\u0430\u0446\u0438\u0438 \u0438\u043d\u0436\u0435\u043d\u0435\u0440\u043d\u043e\u0439 \u0438 \u0442\u0440\u0430\u043d\u0441\u043f\u043e\u0440\u0442\u043d\u043e\u0439 \u0438\u043d\u0444\u0440\u0430\u0441\u0442\u0440\u0443\u043a\u0442\u0443\u0440\u044b, \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044f \u0442\u0443\u0440\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u043a\u043b\u0430\u0441\u0442\u0435\u0440\u0430 \u0438 \u0441\u043e\u0437\u0434\u0430\u043d\u0438\u044f \u0443\u0441\u043b\u043e\u0432\u0438\u0439 \u0434\u043b\u044f \u043f\u0440\u0438\u0432\u043b\u0435\u0447\u0435\u043d\u0438\u044f \u0438\u043d\u0432\u0435\u0441\u0442\u0438\u0446\u0438\u0439 \u0432 \u0432\u044b\u0441\u043e\u043a\u043e\u0442\u0435\u0445\u043d\u043e\u043b\u043e\u0433\u0438\u0447\u043d\u044b\u0435 \u043f\u0435\u0440\u0435\u0440\u0430\u0431\u0430\u0442\u044b\u0432\u0430\u044e\u0449\u0438\u0435 \u043f\u0440\u043e\u0438\u0437\u0432\u043e\u0434\u0441\u0442\u0432\u0430", "goals": [{"description": "\u0421\u043e\u0437\u0434\u0430\u043d\u0438\u0435 \u043a\u043e\u043c\u0444\u043e\u0440\u0442\u043d\u043e\u0439 \u0433\u043e\u0440\u043e\u0434\u0441\u043a\u043e\u0439 \u0441\u0440\u0435\u0434\u044b \u0438 \u043e\u0431\u0435\u0441\u043f\u0435\u0447\u0435\u043d\u0438\u0435 \u0443\u0441\u0442\u043e\u0439\u0447\u0438\u0432\u043e\u0433\u043e \u0434\u0435\u043c\u043e\u0433\u0440\u0430\u0444\u0438\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u0440\u0430\u0437\u0432\u0438\u0442\u0438\u044f", "tasks": [{"description": "\u0421\u043d\u0438\u0436\u0435\u043d\u0438\u0435 \u043e\u0442\u0442\u043e\u043a\u0430 \u043d\u0430\u0441\u0435\u043b\u0435\u043d\u0438\u044f \u0438 \u0441\u0442\u0430\u0431\u0438\u043b\u0438\u0437\u0430\u0446\u0438\u044f \u0447\u0438\u0441\u043b\u0435\u043d\u043d\u043e\u0441\u0442\u0438 \u043d\u0430\u0441\u0435\u043b\u0435\u043d\u0438\u044f", "indicators": [{"code": "8112023", "name": "\u041c\u0438\u0433\u0440\u0430\u0446\u0438\u043e\u043d\u043d\u044b\u0439 \u043f\u0440\u0438\u0440\u043e\u0441\u0442 (\u0443\u0431\u044b\u043b\u044c)", "target": "\u041c\u0430\u043a\u0441\u0438\u043c\u0438\u0437\u0430\u0446\u0438\u044f"}, {"code": "8112013", "name": "\u0421\u0440\u0435\u0434\u043d\u0435\u0433\u043e\u0434\u043e\u0432\u0430\u044f \u0447\u0438\u0441\u043b\u0435\u043d\u043d\u043e\u0441\u0442\u044c \u043f\u043e\u0441\u0442\u043e\u044f\u043d\u043d\u043e\u0433\u043e \u043d\u0430\u0441\u0435\u043b\u0435\u043d\u0438\u044f", "target": "\u041c\u0430\u043a\u0441\u0438\u043c\u0438\u0437\u0430\u0446\u0438\u044f"}]}, {"description": "\u041f\u043e\u0432\u044b\u0448\u0435\u043d\u0438\u0435 \u0434\u043e\u0441\u0442\u0443\u043f\u043d\u043e\u0441\u0442\u0438 \u0438 \u043a\u0430\u0447\u0435\u0441\u0442\u0432\u0430 \u0436\u0438\u043b\u044c\u044f \u0447\u0435\u0440\u0435\u0437 \u0440\u0435\u0430\u043b\u0438\u0437\u0430\u0446\u0438\u044e \u043f\u0440\u043e\u0433\u0440\u0430\u043c\u043c\u044b \u0440\u0430\u0441\u0441\u0435\u043b\u0435\u043d\u0438\u044f \u0430\u0432\u0430\u0440\u0438\u0439\u043d\u043e\u0433\u043e \u0444\u043e\u043d\u0434\u0430", "indicators": [{"code": "8010001", "name": "\u0412\u0432\u0435\u0434\u0435\u043d\u043e \u0432 \u0434\u0435\u0439\u0441\u0442\u0432\u0438\u0435 \u0436\u0438\u043b\u044b\u0445 \u0434\u043e\u043c\u043e\u0432", "target": "\u041c\u0430\u043a\u0441\u0438\u043c\u0438\u0437\u0430\u0446\u0438\u044f"}, {"code": "8010003", "name": "\u0412\u0432\u0435\u0434\u0435\u043d\u043e \u0436\u0438\u043b\u044c\u044f \u0432 \u043c\u043d\u043e\u0433\u043e\u043a\u0432\u0430\u0440\u0442\u0438\u0440\u043d\u044b\u0445 \u0436\u0438\u043b\u044b\u0445 \u0434\u043e\u043c\u0430\u0445", "target": "\u041c\u0430\u043a\u0441\u0438\u043c\u0438\u0437\u0430\u0446\u0438\u044f"}, {"code": "8211002", "name": "\u0427\u0438\u0441\u043b\u043e \u0436\u0438\u043b\u044b\u0445 \u043a\u0432\u0430\u0440\u0442\u0438\u0440 \u0432 \u0440\u0430\u0441\u0447\u0435\u0442\u0435 \u043d\u0430 1000 \u0447\u0435\u043b\u043e\u0432\u0435\u043a \u043d\u0430\u0441\u0435\u043b\u0435\u043d\u0438\u044f \u2014 \u0432\u0441\u0435\u0433\u043e", "target": "\u041c\u0430\u043a\u0441\u0438\u043c\u0438\u0437\u0430\u0446\u0438\u044f"}]}, {"description": "\u0420\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u0433\u043e\u0440\u043e\u0434\u0441\u